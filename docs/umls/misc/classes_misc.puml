@startuml classes_misc
set namespaceSeparator none
class "ArchiveExtractor" as src.misc.archive_helper.ArchiveExtractor {
  extractor
  check_extracted_flag(destination: Path) -> bool
  create_extrated_flag(destination: Path) -> None
  delete_extracted_path(destination: Path) -> None
  extract(destination: Path) -> None
  extract_if_needed(destination: Path) -> bool
  get_flag_path(destination: Path) -> Path
