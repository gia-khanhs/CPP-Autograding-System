}
class "ExtractorTool" as src.misc.archive_helper.ExtractorTool {
  flag_extension : str
  extract(archive_path: Path, destination: Path) -> None
}
class "RarExtractorTool" as src.misc.archive_helper.RarExtractorTool {
  flag_extension : str
  check_backend() -> bool
  extract(archive_path: Path, destination: Path) -> None
}
class "ZipExtractorTool" as src.misc.archive_helper.ZipExtractorTool {
  flag_extension : str
  extract(archive_path: Path, destination: Path) -> None
}
src.misc.archive_helper.RarExtractorTool --|> src.misc.archive_helper.ExtractorTool
src.misc.archive_helper.ZipExtractorTool --|> src.misc.archive_helper.ExtractorTool
